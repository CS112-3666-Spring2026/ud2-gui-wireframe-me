<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="600.0"
            prefWidth="800.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cs112.ud2.MapController">

    <top>
        <HBox alignment="CENTER" spacing="60.0" style="-fx-background-color: lightgray; -fx-padding: 15;">
            <children>
                <Label fx:id="goldLabel" text="Gold: 100">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>

                <Label fx:id="healthLabel" text="Castle Health: 10">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>

                <Label fx:id="waveLabel" text="Wave: 1">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </top>

    <center>
        <Pane fx:id="gamePane" prefHeight="450.0" prefWidth="800.0" style="-fx-background-color: darkseagreen;">

            <children>
                <Label layoutX="40.0" layoutY="140.0" text="ENEMY START">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>

                <Label layoutX="680.0" layoutY="140.0" text="CASTLE">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <!-- Enemy path -->
                <Line startX="80.0" startY="220.0" endX="700.0" endY="220.0" strokeWidth="8.0" />

                <!-- Enemy placeholder -->
                <Circle fx:id="enemyCircle" centerX="90.0" centerY="220.0" radius="15.0" />

                <!-- Castle placeholder -->
                <Rectangle arcHeight="10.0" arcWidth="10.0" height="80.0" layoutX="700.0" layoutY="180.0" width="60.0" />

                <!-- Tower spots -->
                <Button fx:id="towerSpotOne" layoutX="190.0" layoutY="280.0" prefWidth="120.0" text="Tower Spot" onAction="#onTowerSpotClick"/>
                <Button fx:id="towerSpotTwo" layoutX="420.0" layoutY="280.0" prefWidth="120.0" text="Tower Spot" onAction="#onTowerSpotClick"/>
                <Button fx:id="towerSpotThree" layoutX="305.0" layoutY="330.0" prefWidth="120.0" text="Tower Spot" onAction="#onTowerSpotClick"/>
            </children>

        </Pane>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: lightgray; -fx-padding: 15;">
            <children>
                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button fx:id="backButton" mnemonicParsing="false" onAction="#onBackButtonClick" prefWidth="150.0" text="Back to Title" />
                        <Button fx:id="startWaveButton" mnemonicParsing="false" onAction="#onStartWaveButtonClick" prefWidth="150.0" text="Start Wave" />
                    </children>
                </HBox>

                <Label fx:id="messageLabel" text="Place towers and start the wave!" />
            </children>
        </VBox>
    </bottom>

</BorderPane>